# ═══════════════════════════════════════════════════════════════════
# AI-EMPLOYEE COMMUNITY EDITION — Configuration
# ═══════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the required values.
# NEVER commit .env to git — it contains secrets!
#
# Generate secure random values with:
#   openssl rand -base64 32

# ─── REQUIRED ──────────────────────────────────────────────────────
# The application will NOT start if these are missing.

# Strong passwords / encryption keys (32+ random chars each)
DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
API_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32


# ─── LLM PROVIDER ──────────────────────────────────────────────────
# Set AT LEAST ONE of the following.

# Option A: Claude (Anthropic) via API key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Option B: Claude via OAuth (Claude Pro/Team subscription)
# Login via Web-UI after first start to obtain this automatically
CLAUDE_CODE_OAUTH_TOKEN=

# Option C: OpenAI (GPT-4, GPT-5, o1, o3, etc.)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Default model — one of:
#   claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-6, claude-opus-4-6
#   gpt-4o, gpt-5, o1, o3-mini
DEFAULT_MODEL=claude-sonnet-4-6


# ─── PORTS & URLS ──────────────────────────────────────────────────

# Ports exposed on your host
FRONTEND_PORT=3000
ORCHESTRATOR_PORT=8000

# Frontend → Backend URLs (adjust if you deploy behind a reverse proxy)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# OAuth redirect base URL (used for Google/Microsoft/Apple integrations)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# CORS — leave empty for localhost, set to your domain for remote access
# Example: https://agents.yourcompany.com
CORS_ALLOW_ORIGIN=


# ─── LIMITS ────────────────────────────────────────────────────────

# Max concurrent agent containers
MAX_AGENTS=10

# Max turns per task (prevents infinite loops)
MAX_TURNS=100


# ─── OPTIONAL: TELEGRAM INTEGRATION ────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ─── VERSION PINNING ───────────────────────────────────────────────
# Leave as "latest" for automatic updates, or pin to a specific version.
AI_EMPLOYEE_VERSION=latest
