# Internal reverse proxy - Cloudflare Tunnel terminates TLS
# Caddy routes requests to the correct backend service

:80 {
	# Security headers (defence in depth — also set by FastAPI middleware)
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(self), geolocation=()"
		-Server
	}

	# Kiosk is LOCAL-ONLY. Requests coming through the Cloudflare tunnel carry a
	# Cf-Ray header → 404. Requests from the Pi's own browser hit Caddy directly
	# and have no such header → served. (handle blocks are matched most-specific
	# first, so these win over /api/* and the catch-all.)
	@tunnel header Cf-Ray *
	handle /api/v1/kiosk* {
		route {
			respond @tunnel "Not found" 404
			reverse_proxy ai-employee-orchestrator:8000
		}
	}
	handle /kiosk* {
		route {
			respond @tunnel "Not found" 404
			reverse_proxy ai-employee-frontend:3000
		}
	}

	# API + health endpoints → orchestrator
	handle /api/* {
		reverse_proxy ai-employee-orchestrator:8000
	}

	# Backend healthcheck (for Docker/monitoring) → orchestrator
	# Use /healthz to avoid conflict with frontend /health route
	handle /healthz {
		reverse_proxy ai-employee-orchestrator:8000
	}

	# WebSocket connections → orchestrator
	handle /ws/* {
		reverse_proxy ai-employee-orchestrator:8000
	}

	# OAuth discovery (RFC 8414 / 9728) for the external MCP server — must be at
	# well-known root so MCP clients (OpenWebUI) can find the authorization server.
	handle /.well-known/oauth-authorization-server* {
		reverse_proxy ai-employee-orchestrator:8000
	}
	handle /.well-known/oauth-protected-resource* {
		reverse_proxy ai-employee-orchestrator:8000
	}

	# Immutable hashed build assets (JS/CSS chunks) — safe to cache forever.
	handle /_next/static/* {
		reverse_proxy ai-employee-frontend:3000 {
			header_down Cache-Control "public, max-age=31536000, immutable"
		}
	}

	# Everything else → frontend. The HTML shell must NOT be long-cached by the CDN/
	# browser (Next.js sends s-maxage=1y) — otherwise a new deploy stays invisible
	# because the cached HTML keeps referencing the OLD hashed bundles. header_down
	# overrides the upstream Cache-Control so users always get the current build.
	handle {
		reverse_proxy ai-employee-frontend:3000 {
			header_down Cache-Control "no-cache, must-revalidate"
		}
	}
}
