# AI Employee Platform - Environment Variables
# Copy this file to .env and fill in your values

# Claude Authentication (choose ONE method)
#
# Option A: Anthropic API Key (paid per token - from console.anthropic.com)
ANTHROPIC_API_KEY=
#
# Option B: Claude OAuth Token (uses your Claude Pro/Team subscription - no extra costs)
# Run "claude login" first, then extract token from macOS Keychain
CLAUDE_CODE_OAUTH_TOKEN=
# Refresh token - enables automatic access token renewal (recommended)
CLAUDE_CODE_OAUTH_REFRESH_TOKEN=

# PostgreSQL
DB_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://ai_employee:devpassword@postgres:5432/ai_employee

# Redis
REDIS_URL=redis://redis:6379

# Telegram Bot (optional - get token from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Agent Defaults
DEFAULT_MODEL=claude-sonnet-4-6
MAX_TURNS=100
MAX_AGENTS=10
EXTENDED_THINKING=true  # Enable extended thinking (better reasoning, slower)

# Encryption Key for stored secrets (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# OAuth Integrations (optional - configure to enable)
# Google: https://console.cloud.google.com/apis/credentials
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Microsoft: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
# Apple: https://developer.apple.com/account/resources/identifiers
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY=
# OAuth redirect base URL (default: http://localhost:8000)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
